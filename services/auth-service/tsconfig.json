{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".", 
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@simple-architecture/commons": ["../commons/dist/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}